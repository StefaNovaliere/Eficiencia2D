# Frontend (Next.js) — set this in Vercel dashboard or local .env.local
# Points to your backend service (e.g. Railway, Render, etc.)
NEXT_PUBLIC_API_URL=https://your-backend-service.up.railway.app

# ─── Mercado Pago ───
# Get credentials at: https://www.mercadopago.com.ar/developers/panel/app
# Server-side only (NEVER expose to client)
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_BYPASS_KEY=your-secret-bypass-key

# Client-side (public — safe to expose)
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000
