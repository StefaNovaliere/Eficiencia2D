# Backend (FastAPI) — set these in your Docker host / Railway dashboard

# Path to compiled C++ translator binary
TRANSLATOR_BIN=/usr/local/bin/skp_translator

# Comma-separated allowed CORS origins (your Vercel frontend URL)
CORS_ORIGINS=https://your-app.vercel.app

# Max upload size in bytes (default: 200 MB)
MAX_UPLOAD_BYTES=209715200

# C++ translator subprocess timeout in seconds
TRANSLATOR_TIMEOUT_S=120

# Temp directory for job files
TEMP_DIR=/tmp/eficiencia2d
